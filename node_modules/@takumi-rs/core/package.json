{
  "name": "@takumi-rs/core",
  "version": "1.0.9",
  "keywords": [
    "css",
    "image",
    "jsx",
    "napi",
    "nodejs",
    "react",
    "rendering"
  ],
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "Kane Wang",
    "email": "me@kane.tw",
    "url": "https://kane.tw"
  },
  "repository": {
    "url": "git+https://github.com/kane50613/takumi.git"
  },
  "files": [
    "dist",
    "not-available.js"
  ],
  "type": "module",
  "main": "./dist/export.cjs",
  "module": "./dist/export.mjs",
  "types": "./dist/export.d.cts",
  "exports": {
    ".": {
      "types": "./dist/export.d.cts",
      "workerd": "./not-available.js",
      "browser": "./not-available.js",
      "node": "./dist/export.mjs",
      "import": "./dist/export.mjs",
      "require": "./dist/export.cjs",
      "default": "./dist/export.mjs"
    }
  },
  "scripts": {
    "build": "napi build --release --no-const-enum --platform --esm --strip",
    "build:js": "tsdown && bun scripts/patch-dist-loader.ts",
    "prepublishOnly": "jq '.dependencies[\"@takumi-rs/helpers\"] = .version' package.json > tmp.json && mv tmp.json package.json && bun artifacts && napi prepublish -t npm --no-gh-release",
    "artifacts": "napi create-npm-dirs && napi artifacts && napi version",
    "bench": "bun tests/bench/index.tsx"
  },
  "dependencies": {
    "@takumi-rs/helpers": "1.0.9"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.6.1",
    "@types/bun": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "csstype": "^3.2.3",
    "lucide-react": "catalog:",
    "mitata": "^1.0.34",
    "react": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "napi": {
    "binaryName": "core",
    "dtsHeaderFile": "./src/dts-header.d.ts",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "optionalDependencies": {
    "@takumi-rs/core-darwin-x64": "1.0.9",
    "@takumi-rs/core-darwin-arm64": "1.0.9",
    "@takumi-rs/core-linux-arm64-gnu": "1.0.9",
    "@takumi-rs/core-linux-arm64-musl": "1.0.9",
    "@takumi-rs/core-win32-arm64-msvc": "1.0.9",
    "@takumi-rs/core-linux-x64-gnu": "1.0.9",
    "@takumi-rs/core-linux-x64-musl": "1.0.9",
    "@takumi-rs/core-win32-x64-msvc": "1.0.9"
  }
}