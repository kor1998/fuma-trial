{
  "name": "@takumi-rs/helpers",
  "version": "1.0.9",
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "Kane Wang",
    "email": "me@kane.tw",
    "url": "https://kane.tw"
  },
  "repository": {
    "url": "git+https://github.com/kane50613/takumi.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./html": {
      "types": "./dist/html.d.mts",
      "import": "./dist/html.mjs",
      "require": "./dist/html.cjs",
      "default": "./dist/html.mjs"
    },
    "./jsx": {
      "types": "./dist/jsx.d.mts",
      "import": "./dist/jsx.mjs",
      "require": "./dist/jsx.cjs",
      "default": "./dist/jsx.mjs"
    },
    "./emoji": {
      "types": "./dist/emoji.d.mts",
      "import": "./dist/emoji.mjs",
      "require": "./dist/emoji.cjs",
      "default": "./dist/emoji.mjs"
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "ultrahtml": "^1.6.0"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  }
}
