{
  "name": "takumi-js",
  "version": "1.0.9",
  "description": "All-in-one Takumi package for Node.js and WebAssembly runtimes.",
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "Kane Wang",
    "email": "me@kane.tw",
    "url": "https://kane.tw"
  },
  "repository": {
    "url": "git+https://github.com/kane50613/takumi.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./response": {
      "types": "./dist/response.d.mts",
      "import": "./dist/response.mjs",
      "require": "./dist/response.cjs",
      "default": "./dist/response.mjs"
    },
    "./node": {
      "types": "./dist/node.d.mts",
      "import": "./dist/node.mjs",
      "require": "./dist/node.cjs",
      "default": "./dist/node.mjs"
    },
    "./wasm": {
      "types": "./dist/wasm.d.mts",
      "import": "./dist/wasm.mjs",
      "require": "./dist/wasm.cjs",
      "default": "./dist/wasm.mjs"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.mts",
      "import": "./dist/helpers/index.mjs",
      "require": "./dist/helpers/index.cjs",
      "default": "./dist/helpers/index.mjs"
    },
    "./helpers/emoji": {
      "types": "./dist/helpers/emoji.d.mts",
      "import": "./dist/helpers/emoji.mjs",
      "require": "./dist/helpers/emoji.cjs",
      "default": "./dist/helpers/emoji.mjs"
    },
    "./helpers/jsx": {
      "types": "./dist/helpers/jsx.d.mts",
      "import": "./dist/helpers/jsx.mjs",
      "require": "./dist/helpers/jsx.cjs",
      "default": "./dist/helpers/jsx.mjs"
    }
  },
  "scripts": {
    "prepublishOnly": "jq '.dependencies[\"@takumi-rs/core\"] = .version | .dependencies[\"@takumi-rs/helpers\"] = .version | .dependencies[\"@takumi-rs/wasm\"] = .version' package.json > tmp.json && mv tmp.json package.json",
    "build": "tsdown",
    "test": "bun test",
    "test:bundlers": "bun test tests/bundlers.test.ts"
  },
  "dependencies": {
    "@takumi-rs/core": "1.0.9",
    "@takumi-rs/helpers": "1.0.9",
    "@takumi-rs/wasm": "1.0.9"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "tsdown": "catalog:"
  }
}
